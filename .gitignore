# --- runtime data plane (written into the target project's .cc-local-loop/, not here) ---
# Exclude the CONTENTS (not the dir) so the promotion audit trail can be re-included — git can't un-ignore a child
# whose parent DIR is excluded. Keep in sync with run-loop step 0's .git/info/exclude carve-out.
.cc-local-loop/*
!.cc-local-loop/promoted.jsonl
*.ledger.jsonl
candidates.jsonl
events.jsonl
# --- eval workspace (regenerated; never hand-edited) ---
evals/workspace/
# --- ccloop data plane (feature-scoped; written into specs/<feature>/ccloop/ at runtime) ---
specs/*/ccloop/*
!specs/*/ccloop/promoted.jsonl
# --- agent-local (regenerable via `specify`; may hold local state — spec-kit security guidance) ---
.claude/
# --- spec-kit volatile ---
.specify/**/.cache/
.specify/workflows/runs/
# --- session backups from the 0.11.5 → 0.12.4 re-init (safe to delete) ---
.specify.bak-*
.claude.bak-*
# --- OS / editor ---
.DS_Store
*.swp
Thumbs.db
node_modules/
__pycache__/
*.pyc
